{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "profile",
  "description": "profile data from relay",
  "type": "object",
  "required": ["type", "organization_id", "project_id", "key_id", "payload"],
  "additionalProperties": true,
  "properties": {
    "type": { "type": "string" },
    "organization_id": { "type": "integer" },
    "project_id": { "type": "integer" },
    "key_id": { "type": "integer" },
    "received": { "type": "integer" },
    "payload": {
      "description": "bytes"
    },
    "attachments": {
      "description": "files related to the profile chunk (e.g. a raw profile), stored in the object store",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "stored_id"],
        "properties": {
          "name": { "type": "string" },
          "content_type": { "type": "string" },
          "stored_id": { "type": "string" }
        }
      }
    }
  }
}
